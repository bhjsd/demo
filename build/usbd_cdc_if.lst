 260:USB_DEVICE/App/usbd_cdc_if.c **** /**
 261:USB_DEVICE/App/usbd_cdc_if.c ****   * @brief Data received over USB OUT endpoint are sent over CDC interface
 262:USB_DEVICE/App/usbd_cdc_if.c ****   *         through this function.
 263:USB_DEVICE/App/usbd_cdc_if.c ****   *
 264:USB_DEVICE/App/usbd_cdc_if.c ****   *         @note
 265:USB_DEVICE/App/usbd_cdc_if.c ****   *         This function will issue a NAK packet on any OUT packet received on
 266:USB_DEVICE/App/usbd_cdc_if.c ****   *         USB endpoint until exiting this function. If you exit this function
 267:USB_DEVICE/App/usbd_cdc_if.c ****   *         before transfer is complete on CDC interface (ie. using DMA controller)
 268:USB_DEVICE/App/usbd_cdc_if.c ****   *         it will result in receiving more data while previous ones are still
 269:USB_DEVICE/App/usbd_cdc_if.c ****   *         not sent.
 270:USB_DEVICE/App/usbd_cdc_if.c ****   *
 271:USB_DEVICE/App/usbd_cdc_if.c ****   * @param  Buf: Buffer of data to be received
 272:USB_DEVICE/App/usbd_cdc_if.c ****   * @param  Len: Number of data received (in bytes)
 273:USB_DEVICE/App/usbd_cdc_if.c ****   * @retval Result of the operation: USBD_OK if all operations are OK else USBD_FAILL
 274:USB_DEVICE/App/usbd_cdc_if.c ****   */
 275:USB_DEVICE/App/usbd_cdc_if.c **** static int8_t CDC_Receive_HS(uint8_t* Buf, uint32_t *Len)
ARM GAS  C:\Users\ADMINI~1\AppData\Local\Temp\cc6jSshL.s 			page 7


