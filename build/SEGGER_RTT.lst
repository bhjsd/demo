 971:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // Special case: First check that assumed RdOff == 0 calculated that last element before wrap
 972:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // But 2nd check (considering space until wrap-around and until RdOff) revealed that RdOff is
 973:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // In this case, we may use a copy straight until buffer end anyway without needing to copy 2
 974:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // Therefore, check if 2nd memcpy is necessary at all
 975:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       //
