 450:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       *pDst++ = *pData++;
 451:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     };
 452:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     RTT__DMB();                     // Force data write to be complete before writing the <WrOff>, 
 453:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pRing->WrOff = WrOff;
 454:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #else
 455:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     SEGGER_RTT_MEMCPY((void*)pDst, pData, NumBytes);
 456:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     RTT__DMB();                     // Force data write to be complete before writing the <WrOff>, 
 457:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pRing->WrOff = WrOff + NumBytes;
 458:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #endif
 459:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   } else {
