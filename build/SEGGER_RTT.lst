 356:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 357:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Function description
 358:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    Stores a specified number of characters in SEGGER RTT ring buffer
 359:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    and updates the associated write pointer which is periodically
 360:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    read by the host.
 361:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    The caller is responsible for managing the write chunk sizes as
 362:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    _WriteBlocking() will block until all data has been posted successfully.
 363:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 364:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Parameters
 365:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    pRing        Ring buffer to post to.
 366:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    pBuffer      Pointer to character array. Does not need to point to a \0 terminated string.
 367:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    NumBytes     Number of bytes to be stored in the SEGGER RTT control block.
 368:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 369:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Return value
 370:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    >= 0 - Number of bytes written into buffer.
 371:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** */
 372:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** static unsigned _WriteBlocking(SEGGER_RTT_BUFFER_UP* pRing, const char* pBuffer, unsigned NumBytes)
 373:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned NumBytesToWrite;
