 982:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       return 1;
 983:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     }
 984:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   } else {                                             // Potential case 4)
