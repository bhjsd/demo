 440:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   WrOff = pRing->WrOff;
 441:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   Rem = pRing->SizeOfBuffer - WrOff;
 442:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   if (Rem > NumBytes) {
 443:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     //
 444:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     // All data fits before wrap around
 445:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     //
 446:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pDst = (pRing->pBuffer + WrOff) + SEGGER_RTT_UNCACHED_OFF;
