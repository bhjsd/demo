 385:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     if (RdOff > WrOff) {
 386:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       NumBytesToWrite = RdOff - WrOff - 1u;
 387:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     } else {
 388:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       NumBytesToWrite = pRing->SizeOfBuffer - (WrOff - RdOff + 1u);
 389:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     }
 390:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     NumBytesToWrite = MIN(NumBytesToWrite, (pRing->SizeOfBuffer - WrOff));      // Number of bytes 
 391:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     NumBytesToWrite = MIN(NumBytesToWrite, NumBytes);
 392:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pDst = (pRing->pBuffer + WrOff) + SEGGER_RTT_UNCACHED_OFF;
