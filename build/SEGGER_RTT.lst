 978:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****         memcpy((void*)pDst, pData + Rem, NumBytes);
 979:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       }
