 376:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned WrOff;
 377:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   volatile char* pDst;
 378:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //
 379:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   // Write data to buffer and handle wrap-around if necessary
 380:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //
 381:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   NumBytesWritten = 0u;
