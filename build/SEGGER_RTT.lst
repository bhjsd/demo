 479:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     SEGGER_RTT_MEMCPY((void*)pDst, pData, NumBytesAtOnce);
 480:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     NumBytesAtOnce = NumBytes - Rem;
 481:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pDst = pRing->pBuffer + SEGGER_RTT_UNCACHED_OFF;
 482:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     SEGGER_RTT_MEMCPY((void*)pDst, pData + Rem, NumBytesAtOnce);
 483:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     RTT__DMB();                     // Force data write to be complete before writing the <WrOff>, 
 484:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pRing->WrOff = NumBytesAtOnce;
