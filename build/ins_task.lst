 192:modules/imu/ins_task.c **** /**
 193:modules/imu/ins_task.c ****  * @brief          Transform 3dvector from BodyFrame to EarthFrame
 194:modules/imu/ins_task.c ****  * @param[1]       vector in BodyFrame
 195:modules/imu/ins_task.c ****  * @param[2]       vector in EarthFrame
 196:modules/imu/ins_task.c ****  * @param[3]       quaternion
 197:modules/imu/ins_task.c ****  */
 198:modules/imu/ins_task.c **** void BodyFrameToEarthFrame(const float *vecBF, float *vecEF, float *q)
 199:modules/imu/ins_task.c **** {
 200:modules/imu/ins_task.c ****     vecEF[0] = 2.0f * ((0.5f - q[2] * q[2] - q[3] * q[3]) * vecBF[0] +
 201:modules/imu/ins_task.c ****                        (q[1] * q[2] - q[0] * q[3]) * vecBF[1] +
 202:modules/imu/ins_task.c ****                        (q[1] * q[3] + q[0] * q[2]) * vecBF[2]);
 203:modules/imu/ins_task.c **** 
 204:modules/imu/ins_task.c ****     vecEF[1] = 2.0f * ((q[1] * q[2] + q[0] * q[3]) * vecBF[0] +
 205:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[3] * q[3]) * vecBF[1] +
 206:modules/imu/ins_task.c ****                        (q[2] * q[3] - q[0] * q[1]) * vecBF[2]);
 207:modules/imu/ins_task.c **** 
 208:modules/imu/ins_task.c ****     vecEF[2] = 2.0f * ((q[1] * q[3] - q[0] * q[2]) * vecBF[0] +
 209:modules/imu/ins_task.c ****                        (q[2] * q[3] + q[0] * q[1]) * vecBF[1] +
 210:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[2] * q[2]) * vecBF[2]);
 211:modules/imu/ins_task.c **** }
 212:modules/imu/ins_task.c **** 
 213:modules/imu/ins_task.c **** /**
 214:modules/imu/ins_task.c ****  * @brief          Transform 3dvector from EarthFrame to BodyFrame
 215:modules/imu/ins_task.c ****  * @param[1]       vector in EarthFrame
 216:modules/imu/ins_task.c ****  * @param[2]       vector in BodyFrame
 217:modules/imu/ins_task.c ****  * @param[3]       quaternion
 218:modules/imu/ins_task.c ****  */
 219:modules/imu/ins_task.c **** void EarthFrameToBodyFrame(const float *vecEF, float *vecBF, float *q)
 220:modules/imu/ins_task.c **** {
 221:modules/imu/ins_task.c ****     vecBF[0] = 2.0f * ((0.5f - q[2] * q[2] - q[3] * q[3]) * vecEF[0] +
 222:modules/imu/ins_task.c ****                        (q[1] * q[2] + q[0] * q[3]) * vecEF[1] +
 223:modules/imu/ins_task.c ****                        (q[1] * q[3] - q[0] * q[2]) * vecEF[2]);
 224:modules/imu/ins_task.c **** 
 225:modules/imu/ins_task.c ****     vecBF[1] = 2.0f * ((q[1] * q[2] - q[0] * q[3]) * vecEF[0] +
 226:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[3] * q[3]) * vecEF[1] +
 227:modules/imu/ins_task.c ****                        (q[2] * q[3] + q[0] * q[1]) * vecEF[2]);
 228:modules/imu/ins_task.c **** 
 229:modules/imu/ins_task.c ****     vecBF[2] = 2.0f * ((q[1] * q[3] + q[0] * q[2]) * vecEF[0] +
 230:modules/imu/ins_task.c ****                        (q[2] * q[3] - q[0] * q[1]) * vecEF[1] +
 231:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[2] * q[2]) * vecEF[2]);
 232:modules/imu/ins_task.c **** }
