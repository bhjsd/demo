 267:modules/algorithm/QuaternionEKF.c ****     if (kf->P_data[28] > 10000)
 268:modules/algorithm/QuaternionEKF.c ****     {
 269:modules/algorithm/QuaternionEKF.c ****         kf->P_data[28] = 10000;
 270:modules/algorithm/QuaternionEKF.c ****     }
